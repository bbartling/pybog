+  /**
+   * Helper methods for webhook URL construction
+   */
+  private getStepFromAction(action: string): string | undefined {
+    switch (action) {
+      case 'approve_text':
+      case 'edit_text':
+      case 'retry_extraction':
+        return 'text_review';
+      case 'approve_analysis':
+      case 'refine_analysis':
+        return 'analysis_review';
+      case 'confirm':
+      case 'regenerate':
+      case 'cancel':
+        return 'generation_confirmation';
+      default:
+        return undefined;
+    }
+  }
+
+  private getStatusFromAction(action: string): string | undefined {
+    switch (action) {
+      case 'approve_text':
+      case 'edit_text':
+        return 'text_extracted';
+      case 'retry_extraction':
+        return 'text_review_required';
+      case 'approve_analysis':
+      case 'refine_analysis':
+        return 'analysis_complete';
+      case 'confirm':
+      case 'regenerate':
+      case 'cancel':
+        return 'generation_complete';
+      default:
+        return undefined;
+    }

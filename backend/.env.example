# PyBOG Backend Configuration
# Copy this file to .env and update the values as needed

# =============================================================================
# Environment Settings
# =============================================================================
ENVIRONMENT=development
DEBUG=true
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# =============================================================================
# Database Configuration
# =============================================================================
# PostgreSQL connection URL
DATABASE_URL=postgresql://pybog:pybog123@localhost:5432/pybog

# Database connection pool settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# =============================================================================
# File Management & Retention
# =============================================================================
# File cleanup thresholds (in days)
FILE_ARCHIVE_THRESHOLD_DAYS=30
FILE_PURGE_THRESHOLD_DAYS=90

# Cleanup task interval (in hours)
FILE_CLEANUP_INTERVAL_HOURS=1

# Maximum file size for BYTEA storage (in MB)
# Files larger than this will be stored on disk
MAX_FILE_SIZE_MB=10

# =============================================================================
# WebSocket Configuration
# =============================================================================
# Maximum WebSocket connections per session
WS_MAX_CONNECTIONS_PER_SESSION=5

# WebSocket timeouts and limits
WS_CONNECTION_TIMEOUT_SECONDS=300
WS_PING_INTERVAL_SECONDS=30
WS_MAX_MESSAGE_SIZE_KB=1024

# Event replay limit for session resume
WS_EVENT_REPLAY_LIMIT=10

# =============================================================================
# LangChain & LLM Configuration
# =============================================================================
# OpenAI API key (required for production)
OPENAI_API_KEY=your_openai_api_key_here

# LLM model settings
LLM_MODEL_NAME=gpt-3.5-turbo
LLM_MAX_TOKENS=2000
LLM_TEMPERATURE=0.7
LLM_STREAMING_ENABLED=true

# =============================================================================
# CORS Configuration
# =============================================================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# =============================================================================
# Development Notes
# =============================================================================
# 1. Make sure PostgreSQL is running on the specified DATABASE_URL
# 2. For production, set ENVIRONMENT=production and provide OPENAI_API_KEY
# 3. Adjust file retention thresholds based on storage requirements
# 4. WebSocket limits can be tuned based on expected concurrent users
# 5. CORS_ORIGINS should include your frontend URL(s)
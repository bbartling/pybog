# PyBOG Environment Configuration
# Copy this file to .env and update the values

# OpenAI API Key (required for document analysis and BOG generation)
OPENAI_API_KEY=your_openai_api_key_here

# Database Configuration
POSTGRES_DB=pybog
POSTGRES_USER=pybog
POSTGRES_PASSWORD=pybog123

# Application Settings
ENVIRONMENT=development
API_PORT=8000
FRONTEND_PORT=3000

# Database URL for FastAPI backend
DATABASE_URL=postgresql://pybog:pybog123@postgres:5432/pybog

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# File Upload Limits
MAX_FILE_SIZE=10485760
MAX_FILES_PER_SESSION=50

# File Cleanup Settings (in days)
ARCHIVE_THRESHOLD_DAYS=30
PURGE_THRESHOLD_DAYS=90

# WebSocket Configuration
WEBSOCKET_MAX_CONNECTIONS=100
WEBSOCKET_HEARTBEAT_INTERVAL=30

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Logging
LOG_LEVEL=INFO

# Security (change in production)
JWT_SECRET=your_jwt_secret_here_change_in_production

# Docker Monitoring
DOCKER_MONITORING=true
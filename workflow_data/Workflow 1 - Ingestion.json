          "id": "AS0epP0l0NsQnl5k",
          "name": "OpenAi account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "let text='';try{text=$json.data[0].message.content;}catch(e){text='Extraction failed.';}return {json:{...$json,extracted_text:text}};"
      },
      "id": "430cf4e3-5a8e-496a-a19c-9aa576e076ca",
      "name": "Get Extracted Text",

    {
      "parameters": {
        "jsCode": "const item=$input.first();const data=item.json;const files=[];let index=0;while(item.binary[`files${index}`]){const file=item.binary[`files${index}`];files.push({filename:file.fileName,mimeType:file.mimeType,binaryKey:`files${index}`});index++;}return {json:{sessionId:data.sessionId||Date.now().toString(),userMessage:data.message||'',conversationHistory:data.history||[],files}};"
      },
      "id": "0a739fe0-fce0-4878-9742-f6ee6ece3211",
      "name": "Initialize Conversation",

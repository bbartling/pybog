      "type": "n8n-nodes-base.aggregate",
      "typeVersion": 1,
      "position": [
        800,
        64
      ]
    },
    {
      "parameters": {
        "jsCode": "const items=$input.all();const text=items.map(i=>`--- ${i.json.filename||'file'} ---\\n${i.json.extracted_text}`).join('\\n\\n');const original=items[0].json;return {json:{sessionId:original.sessionId,userMessage:original.userMessage,conversationHistory:original.conversationHistory,extracted_text:text}};"
      },
      "id": "94a41f9a-13ca-4a15-ad85-1b86a1cf5c30",
      "name": "Concatenate Text",
      "type": "n8n-nodes-base.code",
